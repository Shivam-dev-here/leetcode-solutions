   "source": [
    "# Squares of a Sorted Array\n",
    "\n",
    "#### Solution\n",
    "---"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "048e1adb",
   "metadata": {
    "vscode": {
     "languageId": "plaintext"
    }
   },
   "outputs": [],
   "source": [
    "class Solution(object):\n",
    "    def sortedSquares(self, nums):\n",
    "        arr=[]\n",
    "        for num in nums:\n",
    "            arr.append(num**2)\n",
    "            \n",
    "        arr.sort()\n",
    "        return arr"
   ]
  }
